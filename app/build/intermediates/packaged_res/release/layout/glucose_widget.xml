<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Container for the main circle to ensure it stays somewhat circular -->
    <RelativeLayout
        android:id="@+id/main_circle_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="24dp"
        android:background="@drawable/circular_widget_background"
        android:padding="20dp">

        <!-- Info quadrants -->
        <TextView
            android:id="@+id/widget_avg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:text="--"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_a1c"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:text="--"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textStyle="bold" />

        <!-- Central Value -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:id="@+id/widget_last_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="200"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#6750A4"
                android:includeFontPadding="false" />
                
            <TextView
                android:id="@+id/widget_last_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoje, 23:25"
                android:textSize="12sp"
                android:textColor="#49454F" />
        </LinearLayout>

        <!-- Bottom range -->
        <TextView
            android:id="@+id/widget_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:text="--/--"
            android:textSize="11sp"
            android:textColor="#757575" />

    </RelativeLayout>

    <!-- Overlapping Add Button (Rounded Square) -->
    <RelativeLayout
        android:id="@+id/widget_btn_add"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/rounded_add_button"
        android:elevation="8dp">
        
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerInParent="true"
            android:src="@android:drawable/ic_input_add"
            android:tint="#FFFFFF" />
    </RelativeLayout>

</RelativeLayout>
